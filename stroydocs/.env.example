# Timeweb Cloud S3
S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=cd6fe651-d93e-4846-b3ed-c99732c0fee1
S3_ACCESS_KEY=<twc_access_key>
S3_SECRET_KEY=<twc_secret_key>

# Timeweb Managed PostgreSQL
DATABASE_URL=postgresql://stroydocs:stroydocs@localhost:5432/stroydocs

# Timeweb Managed Redis
REDIS_URL=redis://localhost:6379

# Yandex Cloud (YandexGPT парсинг смет)
YANDEX_CLOUD_API_KEY=<yandex_api_key>
YANDEX_FOLDER_ID=<yandex_folder_id>
YANDEX_GPT_MODEL=yandexgpt/latest
YANDEX_SPEECHKIT_API_KEY=    # Yandex SpeechKit для голосового ввода (Модуль 16 Фаза 5)

# NextAuth
NEXTAUTH_SECRET=your-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Cron endpoints (Bearer token for automated schedulers)
CRON_SECRET=your-cron-secret-change-in-production

# Admin endpoints (Bearer token for CI/scripts; session ADMIN role also accepted)
ADMIN_SECRET=your-admin-secret-change-in-production

# App
APP_URL=http://localhost:3000

# Яндекс.Карты (виджет «Карта объектов» на дашборде)
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=<yandex_maps_api_key>

# SMTP (email-уведомления: согласование, напоминания)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@stroydocs.ru
SMTP_PASS=<smtp_password>
SMTP_FROM="StroyDocs <noreply@stroydocs.ru>"

# IfcOpenShell Python-микросервис (services/ifc-service/)
# Локально: http://localhost:8001
# В docker-compose: http://ifc-service:8001
IFC_SERVICE_URL=http://localhost:8001

# Push-уведомления (Web Push VAPID — Модуль 16 PWA)
# Сгенерировать ключи: npx web-push generate-vapid-keys --json
# VAPID публичный ключ (доступен на клиенте)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<your_vapid_public_key>
# VAPID приватный ключ (только на сервере, не раскрывать!)
VAPID_PRIVATE_KEY=<your_vapid_private_key>
# Тема VAPID (email или URL)
VAPID_SUBJECT=mailto:noreply@stroydocs.ru

# ЮKassa (приём платежей — Модуль 15 Фаза 3)
# Тестовые ключи: https://dashboard.yookassa.ru/
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
# ФЗ-54 чеки — включить в ЛК ЮKassa → Настройки → Чеки
# VAT: 1=без НДС (ИП УСН), 2=НДС 0%, 7=НДС 22% (с 2026)
YOOKASSA_RECEIPTS_ENABLED=false
YOOKASSA_VAT_CODE=1
