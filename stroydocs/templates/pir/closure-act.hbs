<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Times New Roman', Times, serif;
      font-size: 12pt;
      line-height: 1.5;
      padding: 20mm 15mm 20mm 25mm;
      color: #000;
    }
    .header { text-align: center; margin-bottom: 20px; }
    .header h1 { font-size: 14pt; font-weight: bold; text-transform: uppercase; }
    .header .subtitle { font-size: 12pt; margin-top: 4px; }
    .requisites { margin-bottom: 20px; }
    .requisites table {
      border: none;
      border-collapse: collapse;
      width: auto;
    }
    .requisites td {
      border: none;
      padding: 3px 8px 3px 0;
      font-size: 11pt;
    }
    .requisites td.label { font-weight: bold; white-space: nowrap; }
    table.items {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 4px;
      font-size: 11pt;
    }
    table.items th {
      background: #e8e8e8;
      border: 1px solid #000;
      padding: 5px 8px;
      text-align: center;
      font-weight: bold;
    }
    table.items td {
      border: 1px solid #000;
      padding: 5px 8px;
      vertical-align: top;
    }
    td.num { text-align: center; width: 40px; }
    td.name { width: 40%; }
    td.unit { text-align: center; width: 10%; }
    td.vol  { text-align: right; width: 12%; }
    td.amt  { text-align: right; width: 18%; }
    .total-row {
      text-align: right;
      font-weight: bold;
      font-size: 12pt;
      margin-top: 4px;
      margin-bottom: 20px;
      padding-right: 4px;
    }
    .signatures {
      margin-top: 40px;
      display: flex;
      justify-content: space-between;
      gap: 60px;
    }
    .sig-block { flex: 1; }
    .sig-block .role { font-weight: bold; font-size: 11pt; margin-bottom: 6px; }
    .sig-line {
      border-bottom: 1px solid #000;
      margin-top: 30px;
      margin-bottom: 4px;
    }
    .sig-hint { font-size: 9pt; color: #555; }
    .footer {
      margin-top: 30px;
      font-size: 9pt;
      color: #888;
      text-align: right;
    }
    .no-items {
      text-align: center;
      color: #888;
      font-style: italic;
      padding: 20px;
    }
  </style>
</head>
<body>

  <div class="header">
    <h1>Акт закрытия ПИР</h1>
    <div class="subtitle">№&nbsp;{{number}}</div>
  </div>

  <table class="requisites">
    <tr>
      <td class="label">Период:</td>
      <td>{{periodStart}} — {{periodEnd}}</td>
    </tr>
    <tr>
      <td class="label">Подрядчик:</td>
      <td>{{contractorOrgName}}</td>
    </tr>
    <tr>
      <td class="label">Заказчик:</td>
      <td>{{customerOrgName}}</td>
    </tr>
  </table>

  <table class="items">
    <thead>
      <tr>
        <th style="width:40px;">№</th>
        <th>Наименование работ</th>
        <th style="width:10%;">Ед.&nbsp;изм.</th>
        <th style="width:12%;">Объём</th>
        <th style="width:18%;">Стоимость,&nbsp;руб.</th>
      </tr>
    </thead>
    <tbody>
      {{#if items.length}}
        {{#each items}}
        <tr>
          <td class="num">{{addOne @index}}</td>
          <td class="name">{{this.workName}}</td>
          <td class="unit">{{this.unit}}</td>
          <td class="vol">{{this.volume}}</td>
          <td class="amt">{{this.amount}}</td>
        </tr>
        {{/each}}
      {{else}}
        <tr><td colspan="5" class="no-items">Позиции не добавлены</td></tr>
      {{/if}}
    </tbody>
  </table>

  <div class="total-row">ИТОГО: {{totalAmount}}&nbsp;руб.</div>

  <div class="signatures">
    <div class="sig-block">
      <div class="role">Подрядчик:</div>
      <div class="sig-line"></div>
      <div class="sig-hint">{{contractorOrgName}}</div>
    </div>
    <div class="sig-block">
      <div class="role">Заказчик:</div>
      <div class="sig-line"></div>
      <div class="sig-hint">{{customerOrgName}}</div>
    </div>
  </div>

  <div class="footer">Сформировано: {{generatedAt}}</div>

</body>
</html>
