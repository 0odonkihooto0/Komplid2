<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Arial, Helvetica, sans-serif; font-size: 12px; color: #1a1a1a; padding: 20px; }
  h1 { font-size: 16px; text-align: center; margin-bottom: 4px; font-weight: bold; }
  .report-subtitle { text-align: center; color: #555; font-size: 11px; margin-bottom: 24px; }
  .block { margin-bottom: 28px; border-top: 2px solid #2563EB; padding-top: 12px; page-break-inside: avoid; }
  .block-title { font-size: 13px; font-weight: bold; color: #2563EB; margin-bottom: 10px; }
  table { width: 100%; border-collapse: collapse; margin: 6px 0; font-size: 11px; }
  th, td { border: 1px solid #ccc; padding: 4px 6px; text-align: left; vertical-align: top; }
  th { background-color: #e8f0fe; font-weight: bold; text-align: center; }
  .text-right { text-align: right; }
  .text-center { text-align: center; }
  .total-row { font-weight: bold; background-color: #f5f5f5; }
  .kv-table td:first-child { font-weight: bold; width: 40%; color: #333; }
  .badge { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 10px; }
  .badge-open { background: #fee2e2; color: #b91c1c; }
  .badge-closed { background: #dcfce7; color: #15803d; }
  .overdue { color: #dc2626; font-weight: bold; }
  .critical { background: #fff3cd; }
  .progress-bar-wrap { background: #e5e7eb; border-radius: 4px; height: 8px; width: 100%; }
  .progress-bar-fill { background: #2563EB; border-radius: 4px; height: 8px; }
  .empty { color: #888; font-style: italic; font-size: 11px; }
  .photo-list { padding-left: 18px; font-size: 11px; line-height: 1.8; }
  @page { size: A4; margin: 15mm 15mm 15mm 20mm; }
</style>
</head>
<body>

<h1>Отчёт №{{number}}: {{name}}</h1>
<div class="report-subtitle">Период: {{formatDate periodStart}} — {{formatDate periodEnd}}</div>

{{#each blocks}}
<div class="block">
  <div class="block-title">{{this.title}}</div>

  {{#if (eq this.type "TITLE_PAGE")}}
    {{> title-page this.content}}
  {{else if (eq this.type "WORK_VOLUMES")}}
    {{> work-volumes this.content}}
  {{else if (eq this.type "KS2_ACTS")}}
    {{> ks2-acts this.content}}
  {{else if (eq this.type "ID_STATUS")}}
    {{> id-status this.content}}
  {{else if (eq this.type "DEFECTS_SUMMARY")}}
    {{> defects-summary this.content}}
  {{else if (eq this.type "GPR_PROGRESS")}}
    {{> gpr-progress this.content}}
  {{else if (eq this.type "PHOTO_REPORT")}}
    {{> photo-report this.content}}
  {{else if (eq this.type "FREE_TEXT")}}
    {{> free-text this.content}}
  {{else}}
    <p class="empty">Блок не заполнен или тип не поддерживается.</p>
  {{/if}}
</div>
{{/each}}

</body>
</html>
