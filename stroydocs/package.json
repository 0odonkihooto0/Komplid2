{
  "name": "stroydocs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate && cp node_modules/web-ifc/web-ifc.wasm public/ 2>/dev/null || true",
    "start": "prisma migrate deploy && node server.js",
    "socket": "ts-node --compiler-options {\"module\":\"CommonJS\"} src/server/socket.ts",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:workers": "tsc -p tsconfig.worker.json",
    "worker:ifc": "ts-node --compiler-options {\"module\":\"CommonJS\"} src/lib/workers/parse-ifc.worker.ts"
  },
